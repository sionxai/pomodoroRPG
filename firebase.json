                    "http://localhost:4173",
                    "http://127.0.0.1:4173"
                ]
            }
        },
        "authorizedDomains": [
            "localhost",
            "127.0.0.1",
            "gen-lang-client-0233715929.firebaseapp.com",
            "gen-lang-client-0233715929.web.app"
        ]
